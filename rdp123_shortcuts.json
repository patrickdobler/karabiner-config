{
  "title": "RDP123 Complex Modifications",
  "rules": [
    {
      "description": "Home to Control+A: moveToBeginningOfLine",
      "manipulators": [
        {
          "conditions": [
            {
              "bundle_identifiers": [
                "^ch\\.asd123\\.rdp123"
              ],
              "type": "frontmost_application_unless"
            },
            {
              "identifiers": [
                {
                  "description": "External keyboard only",
                  "is_built_in_keyboard": false
                }
              ],
              "type": "device_if"
            }
          ],
          "from": {
            "key_code": "home"
          },
          "to": [
            {
              "key_code": "a",
              "modifiers": [
                "left_control"
              ]
            }
          ],
          "type": "basic"
        }
      ]
    },
